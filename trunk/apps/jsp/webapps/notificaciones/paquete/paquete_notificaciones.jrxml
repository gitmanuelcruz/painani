	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="pid_paquete" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT 
			a.id_paquete ,
			a.id_usuario_notificador,
			UPPER(b.nombre_completo) AS notificador,
			to_char(a.fecha_programada,'dd/mm/yyyy') AS fecha_programada,
			(CASE 
					 WHEN a.fecha_hora_apertura_operacion IS NULL THEN  'PENDIENTE' ELSE  to_char(a.fecha_hora_apertura_operacion,'dd/mm/yyyy hh24:mi')
			END) AS fecha_hora_apertura_operacion,
			(CASE 
					 WHEN a.fecha_hora_cierre_operacion IS NULL THEN  'PENDIENTE' ELSE  to_char(a.fecha_hora_cierre_operacion,'dd/mm/yyyy hh24:mi')
			END) AS fecha_hora_cierre_operacion
FROM paquetes a
LEFT JOIN usuarios b ON a.id_usuario_notificador = b.id_usuario
WHERE a.id_paquete =  $P!{pid_paquete}]]>
	</queryString>
